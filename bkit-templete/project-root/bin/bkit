#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  bkit run --prompt-file PATH --context-file PATH --output-file PATH [--workflow NAME]

This project-local bkit command provides an offline draft generator for the
infra workflow. It creates conservative Markdown drafts based on the workflow
type and bundled prompt/context.
EOF
}

die() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

extract_workflow() {
  local prompt_file="$1"
  sed -n 's/^- workflow: `\(.*\)`$/\1/p' "$prompt_file" | head -n 1
}

append_context_note() {
  local output_file="$1"
  local prompt_file="$2"
  local context_file="$3"

  {
    printf '\n'
    printf '> Generated by project-local `bkit` fallback. Review against `%s` and `%s` before applying.\n' "$prompt_file" "$context_file"
  } >>"$output_file"
}

write_new_status() {
  local output_file="$1"
  cat >"$output_file" <<'EOF'
# 상태

날짜: `TBD`

## 의도

- 최신 `status`와 `task`를 대조해 오늘 시작 기준의 핵심 작업 축을 한 줄로 정리한다

## 현재 상태

- 최신 `task`의 `진행`에 근거해 실제로 완료되었거나 확인된 사실만 옮긴다
- 전날 `status`의 `현재 상태`를 그대로 복사하지 않는다

## 알려진 이슈

- 아직 해결되지 않은 이슈만 남긴다
- 최신 `task`의 `진행`에서 새로 드러난 미해결 이슈가 있으면 추가한다

## 다음 작업

- 전날 `status`의 `다음 작업` 중 미완료 항목과 최신 `task`의 `보류 / 다음 액션`을 합쳐 바로 이어서 할 일만 남긴다
EOF
}

write_plan_task() {
  local output_file="$1"
  cat >"$output_file" <<'EOF'
# 작업 계획

날짜: `TBD`

## 계획

현재 상태 요약: 최신 `status`의 작업 축을 확인한 뒤 한 줄로 갱신한다.

1. 최신 `status`의 `다음 작업` 첫 번째 축을 조회 가능한 단위로 분해한다
2. 최신 `status`의 `다음 작업` 두 번째 축을 조회 가능한 단위로 분해한다
3. 필요 시 관련 스크립트나 live state 확인 절차를 작업 항목에 명시한다

## 진행

- 시작 전

## 보류 / 다음 액션

1. 실제 실행 결과가 나오면 `진행`을 갱신한다
2. 완료된 항목은 제거하고 남은 항목만 유지한다
EOF
}

write_update_task() {
  local output_file="$1"
  cat >"$output_file" <<'EOF'
## 진행

- 실제로 완료된 작업과 확인된 사실만 기록한다
- 각 항목이 기존 `계획`의 어느 작업 축과 연결되는지 보이게 정리한다

## 보류 / 다음 액션

1. 아직 끝나지 않은 작업만 남긴다
2. 새 이슈가 생겼다면 다음 액션으로 분리한다
EOF
}

write_update_troubleshooting() {
  local output_file="$1"
  cat >"$output_file" <<'EOF'
# Issue Title

## 발생 조건

- 재현 조건을 한두 줄로 정리한다

## 증상

- 사용자가 관측한 증상을 압축해서 정리한다

## 판단 과정

- 어떤 확인으로 기존 문서에 흡수할지, 새 문서를 만들지 판단했는지 적는다

## 근본 원인

- 실제로 확인된 원인만 적는다

## 해결 방법

- 재현 가능한 수정 절차만 남긴다

## 확인 방법

- 해결 후 다시 확인할 명령이나 체크포인트를 적는다

## 검색 키워드

- 관련 키워드를 짧게 나열한다
EOF
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

COMMAND="$1"
shift

case "$COMMAND" in
  -h|--help)
    usage
    exit 0
    ;;
  run)
    ;;
  *)
    die "unsupported command: $COMMAND"
    ;;
esac

PROMPT_FILE=""
CONTEXT_FILE=""
OUTPUT_FILE=""
WORKFLOW=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --prompt-file)
      PROMPT_FILE="${2:-}"
      shift 2
      ;;
    --context-file)
      CONTEXT_FILE="${2:-}"
      shift 2
      ;;
    --output-file)
      OUTPUT_FILE="${2:-}"
      shift 2
      ;;
    --workflow)
      WORKFLOW="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

[[ -n "$PROMPT_FILE" ]] || die "--prompt-file is required"
[[ -n "$CONTEXT_FILE" ]] || die "--context-file is required"
[[ -n "$OUTPUT_FILE" ]] || die "--output-file is required"
[[ -f "$PROMPT_FILE" ]] || die "prompt file not found: $PROMPT_FILE"
[[ -f "$CONTEXT_FILE" ]] || die "context file not found: $CONTEXT_FILE"

if [[ -z "$WORKFLOW" ]]; then
  WORKFLOW="$(extract_workflow "$PROMPT_FILE")"
fi

[[ -n "$WORKFLOW" ]] || die "could not determine workflow"

mkdir -p "$(dirname "$OUTPUT_FILE")"

case "$WORKFLOW" in
  new-status)
    write_new_status "$OUTPUT_FILE"
    ;;
  plan-task)
    write_plan_task "$OUTPUT_FILE"
    ;;
  update-task)
    write_update_task "$OUTPUT_FILE"
    ;;
  update-troubleshooting)
    write_update_troubleshooting "$OUTPUT_FILE"
    ;;
  *)
    die "unsupported workflow: $WORKFLOW"
    ;;
esac

append_context_note "$OUTPUT_FILE" "$PROMPT_FILE" "$CONTEXT_FILE"
