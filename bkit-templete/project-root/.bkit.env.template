# Project-local bkit runner config.
# The default points to the repository-local bkit shim in ./bin/bkit.
# Override this file only if you later install another bkit CLI and want to use it.

export BKIT_RUNNER='"__ROOT_DIR__/bin/bkit" run --prompt-file "__PROMPT_FILE__" --context-file "__CONTEXT_FILE__" --output-file "__OUTPUT_FILE__" --workflow "__WORKFLOW__"'
