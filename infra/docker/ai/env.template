# LangGraph AI Server Configuration
# Copy this file to .env and update with your actual values
# .env.prod 또는 .env.dev 를 참고하여 환경별로 복사 가능

# === LangGraph Server ===
LANGGRAPH_HOST=0.0.0.0
LANGGRAPH_PORT=8123
LANGGRAPH_API_URL=http://0.0.0.0:8123
LANGGRAPH_AUTH_TYPE=none

# === AI / LLM (Required) ===
GOOGLE_API_KEY=your-google-api-key

# === LangSmith (선택, 트레이싱용) ===
# 둘 다 설정 - 일부 컴포넌트는 LANGCHAIN_API_KEY를 사용
LANGSMITH_API_KEY=optional-langsmith-key
LANGCHAIN_API_KEY=optional-langchain-api-key
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=deep-quest
LANGCHAIN_PROJECT=deep-quest
LANGCHAIN_TRACING_V2=false

# === PostgreSQL (docker-compose/K8s 배포 시) ===
POSTGRES_HOST=deepquest-postgres
POSTGRES_PORT=5432
POSTGRES_DB=deepquest
POSTGRES_USER=deepquest
POSTGRES_PASSWORD=change-me

# === Redis (선택, Production) ===
# REDIS_HOST=deepquest-redis
# REDIS_PORT=6379
# REDIS_PASSWORD=

# === 기타 ===
NODE_ENV=development
LOG_LEVEL=info

# === Environment Mode ===
# dev: development, prod: production
ENVIRONMENT=development
