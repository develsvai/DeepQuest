# Docker Compose 레벨 환경변수
# 이 파일을 .env 로 복사한 뒤 필요 시 수정 (infra/docker/ 디렉터리에 둠)
# .env.prod 또는 .env.dev 를 복사해 사용 가능
# docker-compose.yml 과 같은 디렉터리의 .env 는 Compose 가 자동으로 로드합니다.

# Registry & Image (로컬 빌드 기본값; Harbor pull 시 아래처럼 전체 경로로 변경)
# dev: deepquest-ai:dev, deepquest-web:dev / prod: deepquest-ai:prod, deepquest-web:prod
AI_IMAGE=deepquest-ai:dev
WEB_IMAGE=deepquest-web:dev
# Harbor 예: AI_IMAGE=harbor.192.168.0.110.nip.io/deep-quest/ai:prod
DOCKER_REGISTRY=harbor.192.168.0.110.nip.io

# Container names (선택)
# AI_CONTAINER_NAME=deepquest-ai
# WEB_CONTAINER_NAME=deepquest-web

# Host ports (호스트에 매핑할 포트)
AI_PORT=8123
WEB_PORT=3000

# App (Web 서비스에 전달)
# dev: ENVIRONMENT=development, prod: ENVIRONMENT=production
ENVIRONMENT=development
NODE_ENV=development
# dev: http://deepquest-web:3000 또는 http://web:3000, prod: http://web:3000
APP_URL=http://web:3000
# AI_WEBHOOK_SECRET=default_secret

# Healthcheck
# HEALTHCHECK_INTERVAL=30s
# HEALTHCHECK_TIMEOUT=10s

# AI 리소스 (dev: 주석, prod: 활성화)
# AI_CPU_LIMIT=2
# AI_MEMORY_LIMIT=4G
# AI_CPU_RESERVATION=1
# AI_MEMORY_RESERVATION=2G

# Web 리소스 (dev: 주석, prod: 활성화)
# WEB_CPU_LIMIT=2
# WEB_MEMORY_LIMIT=2G
# WEB_CPU_RESERVATION=0.5
# WEB_MEMORY_RESERVATION=512M
