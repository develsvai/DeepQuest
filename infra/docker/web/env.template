# Deep Quest Web Server Configuration
# Copy this file to .env and update with your actual values
# .env.prod 또는 .env.dev 를 참고하여 환경별로 복사 가능

# === App (NODE_ENV, APP_URL은 docker-compose에서 override 가능) ===
APP_URL=http://web:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Database ===
DATABASE_URL=postgresql://deepquest:change-me@deepquest-postgres:5432/deepquest
DIRECT_URL=postgresql://deepquest:change-me@deepquest-postgres:5432/deepquest

# === Clerk Authentication ===
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
CLERK_SECRET_KEY=your-clerk-secret-key
CLERK_WEBHOOK_SIGNING_SECRET=your-clerk-webhook-signing-secret
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/ko/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/ko/dashboard

# === Supabase Storage === 번들 포함
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# === Tailscale Funnel (Optional, prod에서 사용) ===
# TS_AUTHKEY=tskey-auth-your-key

# === LangGraph / AI ===
LANGGRAPH_API_URL=http://deepquest-ai:8123
LANGSMITH_API_KEY=
AI_WEBHOOK_SECRET=default_secret

# === Sentry === 번들 포함
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=development
SENTRY_ALLOW_EMPTY_DSN=true
# wizard가 .env.sentry-build-plugin에 생성한 토큰 사용
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# === Vercel Analytics (Optional) ===
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# === 기타 ===  번들 포함.
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
PORT=3000

# === Environment Mode ===
# dev: development, prod: production
ENVIRONMENT=development
