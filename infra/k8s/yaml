          - podAffinityTerm:
              labelSelector:
                matchLabels:
                  app.kubernetes.io/component: ai
                  app.kubernetes.io/managed-by: kustomize
                  app.kubernetes.io/name: deep-quest
                  app.kubernetes.io/part-of: deep-quest
              topologyKey: kubernetes.io/hostname
            weight: 100
