            app.kubernetes.io/version: 1.0.0
          labels:
            app.kubernetes.io/component: postgres-backup
            app.kubernetes.io/managed-by: kustomize
            app.kubernetes.io/name: deep-quest
            app.kubernetes.io/part-of: deep-quest
        spec:
          containers:
          - command:
            - /bin/sh
            - -c
            - |
              set -e
              BACKUP_DIR=/backups
              TIMESTAMP=$(date +%Y%m%d_%H%M%S)
              BACKUP_FILE="${BACKUP_DIR}/deepquest_${TIMESTAMP}.sql.gz"

              echo "=== Postgres Backup Started ==="
              echo "Timestamp: ${TIMESTAMP}"
              echo "Database: ${PGDATABASE}"
              echo "Target: ${BACKUP_FILE}"

              # pg_dump 실행 및 압축
              pg_dump --verbose --clean --if-exists --no-owner --no-acl | gzip > "${BACKUP_FILE}"

              # 백업 파일 크기 확인
              FILESIZE=$(ls -lh "${BACKUP_FILE}" | awk '{print $5}')
              echo "Backup completed: ${BACKUP_FILE} (${FILESIZE})"

              # 7일 이상 된 백업 삭제
              echo "=== Cleaning old backups (older than 7 days) ==="
              find ${BACKUP_DIR} -name "deepquest_*.sql.gz" -mtime +7 -delete -print || true

              # 현재 백업 목록 출력
              echo "=== Current backups ==="
              ls -lht ${BACKUP_DIR}/deepquest_*.sql.gz 2>/dev/null || echo "No backups found"

              echo "=== Backup Completed Successfully ==="
            env:
            - name: PGHOST
              value: postgres-service
            - name: PGPORT
              value: "5432"
            - name: PGDATABASE
              valueFrom:
                secretKeyRef:
                  key: POSTGRES_DB
                  name: postgres-secret
            - name: PGUSER
              valueFrom:
                secretKeyRef:
                  key: POSTGRES_USER
                  name: postgres-secret
            - name: PGPASSWORD
              valueFrom:
                secretKeyRef:
                  key: POSTGRES_PASSWORD
                  name: postgres-secret
            image: postgres:16-alpine
            imagePullPolicy: IfNotPresent
            name: backup
            resources:
              limits:
                cpu: 500m
                memory: 512Mi
              requests:
                cpu: 100m
                memory: 256Mi
            volumeMounts:
            - mountPath: /backups
              name: backup-storage
          restartPolicy: OnFailure
          volumes:
          - name: backup-storage
            persistentVolumeClaim:
              claimName: postgres-backup
  schedule: 0 18 * * *
  successfulJobsHistoryLimit: 3
  timeZone: Asia/Seoul
