apiVersion: apps/v1
kind: Deployment
metadata:
  labels:
    app.kubernetes.io/component: tailscale-funnel
    app.kubernetes.io/name: deep-quest
    environment: prod
  name: tailscale-funnel
  namespace: deep-quest
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/component: tailscale-funnel
      app.kubernetes.io/name: deep-quest
  template:
    metadata:
      labels:
        app.kubernetes.io/component: tailscale-funnel
        app.kubernetes.io/name: deep-quest
    spec:
      containers:
      - command:
        - sh
        - -c
        - |
          apk add --no-cache socat
          echo "Forwarding localhost:3000 -> web-service:80"
          socat TCP-LISTEN:3000,fork,reuseaddr TCP:web-service:80 &
          sleep 2
          echo ready > /tmp/ready/forwarder
          wait
        image: alpine:3.19
        name: forwarder
        ports:
        - containerPort: 3000
          name: funnel
        resources:
          limits:
            cpu: 100m
            memory: 128Mi
          requests:
            cpu: 10m
            memory: 32Mi
        volumeMounts:
        - mountPath: /tmp/ready
          name: forwarder-ready
      - command:
        - /bin/sh
        - -c
        - |
          # 1. forwarder가 리스닝할 때까지 대기
          echo "Waiting for forwarder..."
          until [ -f /tmp/ready/forwarder ]; do sleep 1; done
          sleep 2
          echo "Forwarder ready."

          # 2. tailscaled 백그라운드 실행
          tailscaled \
            --state=kube:${TS_KUBE_SECRET} \
            --socket=/tmp/tailscaled.sock \
            --tun=userspace-networking &

          # 3. 소켓 생성 대기
          echo "Waiting for tailscaled socket..."
          until [ -S /tmp/tailscaled.sock ]; do sleep 1; done
          echo "Tailscaled socket found."

          # 4. Tailscale 로그인 (Up)
          tailscale --socket=/tmp/tailscaled.sock up \
            --authkey="${TS_AUTHKEY}" \
            --hostname="${TS_HOSTNAME}" \
            --accept-dns=true

          # 5. Funnel: localhost:3000을 HTTPS로 공개
          tailscale --socket=/tmp/tailscaled.sock funnel 3000

          wait
        env:
        - name: TS_KUBE_SECRET
          value: tailscale-funnel-prod-state
        - name: TS_USERSPACE
          value: "true"
        - name: TS_HOSTNAME
          value: deepquest
        - name: TS_AUTHKEY
          valueFrom:
            secretKeyRef:
              key: TS_AUTHKEY
              name: tailscale-auth
        image: ghcr.io/tailscale/tailscale:latest
        name: tailscale
        resources:
          limits:
            cpu: 200m
            memory: 256Mi
          requests:
            cpu: 50m
            memory: 64Mi
        securityContext:
          capabilities:
            add:
            - NET_ADMIN
        volumeMounts:
        - mountPath: /tmp/ready
          name: forwarder-ready
      initContainers:
      - command:
        - sh
        - -c
        - |
          echo "Waiting for web-service..."
          until nc -z web-service 80; do sleep 2; done
          echo "web-service is ready."
        image: busybox:1.36
        name: wait-for-web
      serviceAccountName: deep-quest-sa
      terminationGracePeriodSeconds: 30
      volumes:
      - emptyDir: {}
        name: forwarder-ready
