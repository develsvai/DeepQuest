# Copy this file to .bkit.env and adjust it to your local bkit CLI if needed.
#
# The project default uses the repository-local shim:
#   "__ROOT_DIR__/bin/bkit" run --prompt-file "__PROMPT_FILE__" --context-file "__CONTEXT_FILE__" --output-file "__OUTPUT_FILE__" --workflow "__WORKFLOW__"
# You only need to change this if you later install another bkit CLI and want
# to use that instead.

# Example:
# export BKIT_RUNNER='bkit draft --input "__CONTEXT_FILE__" --prompt "__PROMPT_FILE__" --save "__OUTPUT_FILE__"'
