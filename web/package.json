{
  "name": "deep-quest",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "import-in-the-middle": "1.15.0"
    }
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--inspect' next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "check-all": "pnpm type-check && pnpm lint && pnpm format:check",
    "i18n:check": "pnpm dlx @lingual/i18n-check --locales locales/en locales/ko --source en --format next-intl --ignore 'landing.comparison.table.rows.*' '*.comparison.table.rows.*' 'comparison.table.rows.*'",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:generate": "prisma generate",
    "db:pull": "prisma db pull",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:validate": "prisma validate",
    "db:format": "prisma format"
  },
  "dependencies": {
    "@clerk/localizations": "^3.35.0",
    "@clerk/nextjs": "^6.36.2",
    "@clerk/themes": "^2.4.40",
    "@hookform/resolvers": "^5.2.2",
    "@langchain/core": "^1.1.0",
    "@langchain/langgraph-sdk": "^1.0.3",
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "7.1.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.38.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.86.0",
    "@tanstack/react-query": "^5.90.11",
    "@trpc/client": "^11.7.2",
    "@trpc/react-query": "^11.7.2",
    "@trpc/tanstack-react-query": "^11.7.2",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.555.0",
    "mime": "^4.1.0",
    "next": "16.0.10",
    "next-intl": "^4.5.5",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "posthog-js": "^1.332.0",
    "posthog-node": "^5.24.1",
    "react": "19.2.3",
    "react-day-picker": "^9.11.3",
    "react-dom": "19.2.3",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.66.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.5",
    "svix": "^1.81.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.13",
